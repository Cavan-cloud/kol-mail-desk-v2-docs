# 复制为 .env.cutover 后填入（不要 commit）
#
# 双跑 / 切流演练（P6-T11）环境变量。
# 详见 scripts/cutover/README.md

# --- 数据迁移（复用 migration 脚本）---
# 若已单独维护 .env.migration，可设 MIGRATION_ENV 指向该文件
MIGRATION_ENV=../migration/.env.migration

# --- 新系统健康检查 ---
NEW_API_BASE_URL=https://api-staging.example.com
NEW_WEB_BASE_URL=https://app-staging.example.com

# --- 旧系统（双跑对照，可选）---
LEGACY_WEB_BASE_URL=https://legacy-app.vercel.app

# --- 演练模式 ---
# true = 只跑检查项，不执行 migrate（默认）；false = 全量迁移 + diff
DRY_RUN_ONLY=true

# --- 切流 drill：设为 true 时在末尾打印切流清单但不改 DNS ---
CUTOVER_DRILL=true
